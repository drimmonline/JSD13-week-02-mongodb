    {
      "id": "aaEyv50w1H6vTt4xv4hqN",
      "type": "text",
      "x": 1799.9284905883017,
      "y": -644.9682627166341,
      "width": 779.6167116198271,
      "height": 634.9609375,
      "angle": 0,
